APP_NAME="Template Playground"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Portfolio marketing hub (shell nav). Default matches local portfolio dev-server port.
VISSAI_PORTFOLIO_URL=http://127.0.0.1:3333

# Loopback children — ports assigned at boot by runtime/stack.mjs (ephemeral; not 3000/3001/2091)
DOCS_AGENT_INTERNAL_URL=http://127.0.0.1:0
CHATGPT_MCP_INTERNAL_URL=http://127.0.0.1:0
SPEED_TO_LEAD_INTERNAL_URL=http://127.0.0.1:0

# Template admin/embed URLs (inline on :3333 — override only when staging another origin).
# VISSAI_DENTISTS_TEMPLATE_URL=http://127.0.0.1:3333/websites/dentists
# VISSAI_DENTISTS_TEMPLATE_ADMIN_PATH=/pasiulymas
# VISSAI_MODULUS_TEMPLATE_URL=http://127.0.0.1:3333/websites/modulus
# VISSAI_MODULUS_TEMPLATE_ADMIN_PATH=/admin-hub
# VISSAI_NEWS_CRUD_TEMPLATE_URL=http://127.0.0.1:3333/websites/blog
# VISSAI_NEWS_CRUD_TEMPLATE_ADMIN_PATH=/news/create
# VISSAI_BOOKING_DEMO_URL=http://127.0.0.1:3333/websites/booking

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# Mirror logs to the terminal running `php artisan serve` (stderr) + storage/logs/laravel.log
LOG_STACK=single,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Verbose debug (set all false in tests / CI via phpunit.xml)
LOG_HTTP_VERBOSE=true
LOG_DB_VERBOSE=true
LOG_APP_VERBOSE=true

# Local debug-logger (scripts/debug-logger/); App\Services\DebugLogger — optional override
# DEBUG_LOGGER_URL=http://127.0.0.1:8840/log

DB_CONNECTION=sqlite
# DB_DATABASE is optional; defaults to database/database.sqlite (create empty file before migrate).
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
