{
  "name": "railway_tunnel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HTTP reverse tunnel: Railway edge (single PORT) + local agent to localhost.",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev:server": "tsc && node dist/server.js",
    "agent": "node dist/agent.js",
    "dev:agent": "tsc && node dist/agent.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3"
  }
}
