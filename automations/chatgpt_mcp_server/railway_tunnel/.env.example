# Server (Railway) — set in Railway project variables
PORT=8080
TUNNEL_TOKEN=generate-a-long-random-secret
# Optional
# TUNNEL_WS_PATH=/tunnel
# TUNNEL_MAX_BODY_MB=20
# TUNNEL_REQUEST_TIMEOUT_MS=120000

# Local agent — use on your PC (not on Railway)
# RAILWAY_TUNNEL_SERVER=https://your-service.up.railway.app
# TUNNEL_TOKEN=same-as-above
# LOCAL_URL=http://127.0.0.1:3088
