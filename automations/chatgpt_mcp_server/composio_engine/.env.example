PORT=3088
HOST=0.0.0.0

# Shared API key between Custom GPT and this backend.
INTERNAL_API_KEY=replace_with_strong_shared_key

# Public URL where this backend is reachable (Railway URL in prod).
ENGINE_PUBLIC_URL=https://your-railway-app.up.railway.app

# Where to send users for Composio app onboarding.
# This should be a page where a user can sign in/create account.
COMPOSIO_ONBOARDING_BASE_URL=https://app.composio.dev

# First landing URL for users with no Composio account.
# Must include {provider_connect_url}. Optional placeholders: {provider}, {user_ref}.
COMPOSIO_ONBOARDING_URL_TEMPLATE=https://app.composio.dev/sign-in?next={provider_connect_url}

# Where to send users for provider connection inside Composio.
# Keep placeholders in this file; use real values in .env.
COMPOSIO_CONNECT_URL_TEMPLATE=https://app.composio.dev/connections/new?provider={provider}&user={user_ref}

# Composio Connect OAuth2 authorize endpoint (used by /v1/oauth/composio/*).
COMPOSIO_OAUTH_AUTHORIZE_URL=https://connect.composio.dev/api/v3/auth/dash/oauth2/authorize

# Optional: Composio OAuth app client id from Composio dashboard (or registered at runtime).
# COMPOSIO_OAUTH_CLIENT_ID=

# ---
# Local dev: set ENGINE_PUBLIC_URL to where this process is reachable (match PORT).
# Example: http://127.0.0.1:3088 — then GET /v1/health should show config_ready: true
# when this file is loaded (see src/env.ts + dotenv).
# Production: use your public HTTPS origin (e.g. Railway) for callbacks and Custom GPT.
