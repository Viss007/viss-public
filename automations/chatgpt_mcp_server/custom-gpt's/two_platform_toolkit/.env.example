# Public origin of this API (no trailing slash). Used to build OAuth redirect_uri values.
TOOLKIT_PUBLIC_URL=https://your-subdomain.ngrok-free.app

# Encrypt tokens at rest (32 bytes, base64). Example generation: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# GPT / internal callers send: X-API-Key: <this value>
INTERNAL_API_KEY=

# --- Google (Sheets) OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Default scopes in code: spreadsheets + drive.readonly (optional) — keep minimal for verification

# --- Meta / Instagram OAuth (Facebook Login) ---
# Same app can provide Instagram Graph if IG product + permissions are configured.
META_APP_ID=
META_APP_SECRET=
# Graph API version prefix, e.g. v21.0
META_GRAPH_VERSION=v21.0

# Optional override (default: ./data/connections.json)
# TOOLKIT_CONNECTIONS_PATH=

# Optional: OAuth CSRF pending state file (default: ./data/oauth-pending.json)
# TOOLKIT_OAUTH_PENDING_PATH=

# Optional: comma- or space-separated Meta scopes for Instagram Graph (defaults in src/routes/oauth.ts)
# INSTAGRAM_OAUTH_SCOPES=

# Optional: host for Instagram Send API (default https://graph.instagram.com). See Meta Messaging docs.
# META_IG_MESSAGES_HOST=

# Server bind — `npm run tunnel` uses PORT + TOOLKIT_PUBLIC_URL together.
PORT=3040
HOST=0.0.0.0
