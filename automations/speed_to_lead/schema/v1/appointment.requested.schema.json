{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "speed-lead://v1/appointment.requested",
  "title": "appointment.requested",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lead_id",
    "window_start",
    "window_end",
    "urgency"
  ],
  "properties": {
    "lead_id": {
      "type": "string",
      "minLength": 1
    },
    "window_start": {
      "type": "string",
      "format": "date-time"
    },
    "window_end": {
      "type": "string",
      "format": "date-time"
    },
    "urgency": {
      "type": "string",
      "enum": [
        "same-day",
        "next-day",
        "normal"
      ]
    },
    "notes": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string",
      "format": "uuid"
    }
  }
}
