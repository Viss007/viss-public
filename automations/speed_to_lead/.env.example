# speed_lead — copy to `.env` and adjust (see README)
#   cp .env.example .env   (Unix)   or   Copy-Item .env.example .env   (pwsh)

PORT=3001

# REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Ingress idempotency + bounded queue.add (ms). Default 2000. Set 0 to fall back to 2000 internally.
# REDIS_INGRESS_TIMEOUT_MS=2000

SLACK_WEBHOOK_URL=

# Email alerts (SMTP) — inbox that receives lead notifications
# NOTIFY_EMAIL_TO=you@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# Optional: EMAIL_FROM="Speed Lead <you@gmail.com>"  SMTP_SECURE=1  (465 SSL)

# Twilio SMS — https://console.twilio.com/ (trial: verify destination numbers in console)
# Preferred names (aliases: TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Force console-only stub even if Twilio vars are set
# SMS_FORCE_STUB=1

# SMS stub (after Slack; uses payload.phone or payload.caller)
# Set to 0 to skip SMS entirely in the worker
# SMS_STUB_ENABLED=1

# --- Google OAuth (Gmail API) — https://console.cloud.google.com/ → project → APIs & Services
# Create OAuth client (Web); add Authorized redirect URI exactly as below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public one-runtime (3333 proxy) — use this for local hire-me stack:
GOOGLE_REDIRECT_URI=http://127.0.0.1:3333/automations/speed-to-lead/auth/google/callback
# Direct loopback only (no Laravel proxy):
# GOOGLE_REDIRECT_URI=http://127.0.0.1:3001/auth/google/callback
# Space-separated; tighten to least privilege for production.
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.send
# Optional: canonical public origin when behind HTTPS / reverse proxy.
# PUBLIC_BASE_URL=https://your-domain.example
# Successful OAuth stores refresh token in `.google-tokens.json` (gitignored).
#
# Inbox auto-reply (poll Gmail for unread inbox, reply once per message id)
# GMAIL_INBOUND_ENABLED=1
# GMAIL_POLL_INTERVAL_MS=30000
# GMAIL_AUTO_REPLY_TEXT=Thanks — we got your message (Speed Lead).
# Default query is is:unread in:inbox — if mail is already read, list is empty; override e.g.:
# GMAIL_INBOUND_QUERY=newer_than:1d in:inbox
# GMAIL_INBOUND_VERBOSE=1
# GMAIL_INBOUND_LOG_FILE=logs/gmail-inbound.log
