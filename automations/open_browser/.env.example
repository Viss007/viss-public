# Copy to `.env` and fill in. Committed template — no real secrets.

# Brave executable (optional if installed in default Program Files / PATH)
# BRAVE_EXE=

# First URL to open (default in script is https://chatgpt.com/)
# BRAVE_OPEN_URL=

# Chrome DevTools Protocol port for the automation hook (default 9333)
# BRAVE_CDP_PORT=

# Set to 1 to skip Log in + Continue-with-Google automation
# BRAVE_SKIP_LOGIN_CLICK=

# Milliseconds to wait for auth UI (default 40000 in click-chatgpt-login.mjs)
# BRAVE_LOGIN_CLICK_MS=

# --- Streamed ChatGPT sandbox (Docker / Railway): see browser_agent/sandbox/.env.example ---
