# Portfolio dev server — copy to .env for local preview only.

# Optional: listen on all interfaces (LAN preview). Default: 127.0.0.1
# HOST=0.0.0.0

# Optional: port (default 3333)
# PORT=3333

# Demo iframe URLs injected into HTML meta tags (public hosted endpoints only)
# VISSAI_PLATFORM_URL=https://your-platform.example
# VISSAI_INVOICE_DEMO_URL=https://your-invoice-demo.example/
# VISSAI_TEMPLATE_PLAYGROUND_URL=https://your-templates.example/
# VISSAI_SPEED_LEAD_DEMO_URL=https://your-speed-lead.example/
# VISSAI_AGENT_DESK_URL=https://your-agent-desk.example/
