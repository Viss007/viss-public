# Required for POST /api/process
OPENAI_API_KEY=

# Demo: max "Apdoroti" batches per client IP (lifetime in memory; resets on deploy). Default 5.
# 0 = unlimited
# INVOICE_DEMO_MAX_PROCESSES_PER_IP=5
# INVOICE_TRUST_PROXY=1

# Optional
# OPENAI_VISION_MODEL=gpt-4o
# OPENAI_VISION_MAX_TOKENS=2000
# PORT=3000
# INVOICE_MAX_PAGES=12
# MAX_FILES=25
# JSON_BODY_LIMIT_MB=50
# Verbose logs: stdout + logs/invoices-app.log
# INVOICE_LOG_FILE=logs/invoices-app.log
# INVOICE_LOG_STDOUT=1

# Gmail API — same Web client as other demos; GOOGLE_REDIRECT_URI must match Google Console exactly.
# Local: open http://127.0.0.1:3000/auth/google once (writes demos/invoices_to_excel/.google-tokens.json)
# Railway: add https://YOUR-APP.up.railway.app/auth/google/callback to Authorized redirect URIs, set same in env, then visit /auth/google on that host.
# INVOICE_NOTIFY_EMAIL=your-inbox@gmail.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/auth/google/callback
# gmail.send alone is not enough for users/me/profile during OAuth — include metadata (or gmail.readonly like speed_lead):
# GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.metadata https://www.googleapis.com/auth/gmail.send
# Optional: paste tokens instead of file (Railway):
# GOOGLE_TOKENS_JSON={"refresh_token":"...","scope":"...","token_type":"Bearer"}
# GOOGLE_TOKEN_FILE=.google-tokens.json
# INVOICE_TRUST_PROXY=1
# Optional: email on GET / (homepage) — at most once per client IP per UTC day; pair with INVOICE_NOTIFY_EMAIL
# INVOICE_NOTIFY_VISIT=1
